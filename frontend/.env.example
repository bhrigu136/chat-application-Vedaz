# Optional frontend environment — copy to frontend/.env to override the backend URL.
# If unset, the app uses the default in src/constants/config.js (the deployed Render URL).
#
#   Web / iOS Simulator: http://localhost:3000
#   Android Emulator:    http://10.0.2.2:3000
#   Physical device:     http://<your-PC-LAN-IP>:3000   (both on same Wi-Fi)
#
# EXPO_PUBLIC_SERVER_URL=http://localhost:3000
