# Backend environment variables — copy this file to backend/.env and fill in.

# Server port. Render sets this automatically; defaults to 3000 locally.
PORT=3000

# Supabase Postgres connection string.
# Use the CONNECTION POOLER string (IPv4-compatible, required for Render).
# Supabase dashboard -> Project Settings -> Database -> Connection string ->
# "Connection pooling" (Session mode). It looks like:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# SSL toggle. Leave UNSET for Supabase (SSL is enabled by default).
# Set to "false" ONLY when pointing at a local Postgres without SSL (e.g. Docker).
# DB_SSL=false
